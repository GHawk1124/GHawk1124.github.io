---
import Section from '../Section.astro'
import CVRaw from '@cv'
import type { CV as CVType } from '@/cv'
const CV = CVRaw as CVType
const courses = CV.education[0]?.courses || []

const { className, ...rest } = Astro.props;
---

{courses.length > 0 && (
  <Section title='Classes' className={className} {...rest}>
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 mt-2 font-serif-main text-[16px] text-skin-base/90">
      {courses.map(course => (
        <li class="flex items-center gap-3">
          <span class="w-4 h-px bg-skin-muted/40 shrink-0"></span>
          <span>{course}</span>
        </li>
      ))}
    </ul>
  </Section>
)}

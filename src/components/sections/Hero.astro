---
import CVRaw from '@cv'
import type { CV as CVType } from '@/cv'
const CV = CVRaw as CVType
const basics = CV.basics

import Section from '@/components/Section.astro'
import { Icon } from 'astro-icon/components'

const { name, label, location, profiles, email } = basics
const { city, region, address } = location
---

<Section>
  <div class='flex flex-col gap-6'>
    <div class='info flex flex-col gap-3 pr-8 print:gap-0 print:pr-0'>
      <p class="font-sc text-[12px] tracking-[0.25em] text-skin-muted uppercase mb-1">
        Aerospace Engineering &nbsp;&middot;&nbsp; Software Development
      </p>
      
      <h1 class="text-5xl md:text-6xl font-bold ink-title-hero leading-[0.95] pb-2">
        {name.split(' ')[0]}
        <span class="block italic font-medium text-skin-muted">{name.split(' ')[1]}</span>
      </h1>

      <!-- Elegant vector ornament divider from Claude Designs Portfolio -->
      <svg class="hero-ornament py-2" width="210" height="16" viewBox="0 0 210 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="0" y1="8" x2="86" y2="8" stroke="currentColor" class="text-skin-muted/40" stroke-width="0.6"/>
        <path d="M 95 2 L 105 14 L 115 2" stroke="currentColor" class="text-skin-hue" stroke-width="0.8" fill="none"/>
        <circle cx="105" cy="8" r="2" fill="currentColor" class="text-skin-hue"/>
        <line x1="114" y1="8" x2="210" y2="8" stroke="currentColor" class="text-skin-muted/40" stroke-width="0.6"/>
      </svg>

      <h2 class="text-lg text-skin-muted font-sans font-medium tracking-wide mt-1">
        {label}
      </h2>

      <div class='flex items-center gap-2 text-base text-skin-muted/80 font-sans mt-1'>
        <Icon class='print:hidden' name='mdi:world' width={16} height={16} />
        <span>{address}, {city}, {region}</span>
      </div>

      <footer class='print text-base text-skin-muted font-sans mt-4'>
        {email}
      </footer>
      
      <footer class='print:hidden flex flex-wrap gap-4 mt-6 items-center'>
        {
          email && (
            <a
              href={`mailto:${email}`}
              title={`Send email to me`}
              target='_blank'
              class="foot-link font-sc text-[13px] tracking-[0.16em] uppercase text-skin-muted hover:text-skin-base border-b border-skin-muted/30 pb-0.5 transition-colors"
              rel='noopener noreferrer'>
              Email
            </a>
          )
        }
        {
          profiles.map(({ network, url }) => {
            return (
              <a
                href={url}
                title={`Visit ${name} profile on ${network}`}
                target='_blank'
                class="foot-link font-sc text-[13px] tracking-[0.16em] uppercase text-skin-muted hover:text-skin-base border-b border-skin-muted/30 pb-0.5 transition-colors"
                rel='noopener noreferrer'>
                {network}
              </a>
            )
          })
        }
      </footer>
    </div>
  </div>
</Section>

---
// CV Seal, Download Button and Footer in parchment style
---

<div class='slide-enter flex flex-col w-full justify-center md:col-span-6 print:hidden text-center pb-24 pt-12 items-center font-serif-main'>
  <!-- Custom Seal SVG from Claude Designs Portfolio -->
  <svg class="cv-seal mb-6 text-skin-hue" width="58" height="58" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="32" cy="32" r="30" stroke="currentColor" class="text-skin-muted/40" stroke-width="0.8"/>
    <circle cx="32" cy="32" r="24" stroke="currentColor" class="text-skin-muted/40" stroke-width="0.5"/>
    <line x1="32" y1="10" x2="32" y2="17" stroke="currentColor" class="text-skin-hue" stroke-width="1"/>
    <line x1="32" y1="47" x2="32" y2="54" stroke="currentColor" class="text-skin-hue" stroke-width="1"/>
    <line x1="10" y1="32" x2="17" y2="32" stroke="currentColor" class="text-skin-hue" stroke-width="1"/>
    <line x1="47" y1="32" x2="54" y2="32" stroke="currentColor" class="text-skin-hue" stroke-width="1"/>
    <circle cx="32" cy="32" r="4" fill="none" stroke="currentColor" class="text-skin-hue" stroke-width="0.8"/>
    <circle cx="32" cy="32" r="1.5" fill="currentColor" class="text-skin-hue"/>
    <line x1="18.5" y1="18.5" x2="22.5" y2="22.5" stroke="currentColor" class="text-skin-muted/40" stroke-width="0.6"/>
    <line x1="41.5" y1="41.5" x2="45.5" y2="45.5" stroke="currentColor" class="text-skin-muted/40" stroke-width="0.6"/>
    <line x1="45.5" y1="18.5" x2="41.5" y2="22.5" stroke="currentColor" class="text-skin-muted/40" stroke-width="0.6"/>
    <line x1="18.5" y1="45.5" x2="22.5" y2="41.5" stroke="currentColor" class="text-skin-muted/40" stroke-width="0.6"/>
  </svg>

  <p class="font-sc text-[12px] tracking-[0.3em] text-skin-muted/70 uppercase mb-3">Curriculum Vitae</p>
  
  <h2 class="text-3xl md:text-4xl font-bold ink-title-md mb-3">The Full Record</h2>
  
  <p class="text-[16.5px] text-skin-muted italic max-w-md leading-relaxed mb-8">
    A complete account of projects, professional experience, and academic history — compiled and available for reference.
  </p>

  <div class="flex flex-wrap justify-center gap-3">
    <a
      href="/pdfs/GarrettComes_CV.pdf"
      target="_blank"
      rel="noopener"
      class="cv-btn inline-flex items-center gap-3.5 font-sc text-[13px] tracking-[0.2em] uppercase text-skin-inverted bg-skin-button-accent hover:bg-skin-button-accent-hover px-9 py-4 transition-colors rounded-sm shadow-md"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="opacity-80">
        <path d="M7 1v8M4 6l3 3 3-3M2 11h10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Full CV
    </a>
    <a
      href="/pdfs/GarrettComes_Resume_Aerospace.pdf"
      target="_blank"
      rel="noopener"
      class="cv-btn inline-flex items-center gap-3.5 font-sc text-[13px] tracking-[0.2em] uppercase text-skin-muted border border-skin-muted/40 bg-skin-button-muted/60 hover:text-skin-base px-7 py-4 transition-colors rounded-sm shadow-md"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="opacity-80">
        <path d="M7 1v8M4 6l3 3 3-3M2 11h10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Aerospace Resume
    </a>
    <a
      href="/pdfs/GarrettComes_Resume_Software.pdf"
      target="_blank"
      rel="noopener"
      class="cv-btn inline-flex items-center gap-3.5 font-sc text-[13px] tracking-[0.2em] uppercase text-skin-muted border border-skin-muted/40 bg-skin-button-muted/60 hover:text-skin-base px-7 py-4 transition-colors rounded-sm shadow-md"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="opacity-80">
        <path d="M7 1v8M4 6l3 3 3-3M2 11h10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Software Resume
    </a>
  </div>

  <!-- ROMAN NUMERAL FOOTER MMXXVI (2026) -->
  <div class="mt-20 flex flex-col gap-2 items-center text-[14px] opacity-50">
    <p class="font-sans font-medium tracking-wide">Garrett Comes &middot; Aerospace & Software</p>
    <p class="font-sc text-[11px] tracking-[0.14em] uppercase text-skin-muted/90">MMXXVI</p>
  </div>
</div>

---
import Section from '../Section.astro'
import { Icon } from 'astro-icon/components'

import CVRaw from "@cv";
import type { CV as CVType, Skills } from "@/cv";
const CV = CVRaw as CVType;
const skills = CV.skills;

const languages = skills.filter((s: Skills) => ['Rust', 'Python', 'C++', 'MATLAB / Simulink'].includes(s.name));
const propulsion = skills.filter((s: Skills) => ['Space Propulsion', 'Valves & Fluid Systems', 'Creo CAD', 'CFD & Slosh Analysis', 'Magnetic Simulation & Test'].includes(s.name));
const tools = skills.filter((s: Skills) => ['Embedded Controls', 'Orbital Mechanics', 'GPU Visualization', 'Git & Linux', 'Scientific Computing'].includes(s.name));

const categories = [
  { title: "Software", list: languages },
  { title: "Propulsion", list: propulsion },
  { title: "Analysis & Tools", list: tools }
];

const { className, ...rest } = Astro.props;
---

<Section className={className} title='Skills' {...rest}>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-4 font-serif-main">
    {categories.map(({ title, list }) => (
      <div class="flex flex-col">
        <p class="font-sc text-[12px] tracking-[0.25em] text-skin-muted/70 uppercase pb-2.5 mb-4 border-b border-skin-muted/30">
          {title}
        </p>
        <ul class="flex flex-col gap-3">
          {list.map(({ name, icon, level }) => (
            <li class="flex items-center gap-3 text-[17px] text-skin-base/90" title={level}>
              <span class="w-5 h-px bg-skin-muted/40 shrink-0"></span>
              {icon && <Icon name={icon} class="text-skin-hue inline shrink-0" width={14} height={14} />}
              <span>{name}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</Section>

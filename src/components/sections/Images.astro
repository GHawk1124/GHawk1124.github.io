---
import { Image } from "astro:assets";
import Section from "../Section.astro";

import CVRaw from "@cv";
import type { CV as CVType } from "@/cv";
const CV = CVRaw as CVType;
const images = CV.images;

const { className, ...rest } = Astro.props;
---

{images && (
  <Section className={className} title="Images Gallery" {...rest}>
    {images.intro && <p class="font-serif-main ml-3 text-skin-muted mb-4">{images.intro}</p>}
    <div
      class="grid grid-cols-1 gap-2 p-2 pt-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
    >
      {
        images.list.map(({ image, alt, desc }) => (
          <div class="relative overflow-hidden rounded-lg border border-skin-hue/20 bg-skin-button-accent/20" style="height: 0; padding-bottom: 100%;">
            <a
              href={image}
              data-fancybox="gallery"
              data-caption={desc}
              class="block aspect-square"
            >
              <Image
                src={image}
                alt={alt}
                width={500}
                height={500}
                class="h-full w-full object-cover transition-transform duration-300 hover:scale-105"
              />
            </a>
          </div>
        ))
      }
    </div>
  </Section>
)}

<script>
  import { Fancybox } from "@fancyapps/ui";
  Fancybox.bind('[data-fancybox="gallery"]', { hideScrollbar: false });
</script>

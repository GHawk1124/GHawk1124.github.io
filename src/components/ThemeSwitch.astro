---
import { Icon } from 'astro-icon/components'
---

<div class='inline-flex items-center print:hidden z-10 gap-2'>
  <!-- Play/Pause Animation button -->
  <button
    id='animationToggle'
    class='cursor-pointer p-2 rounded-full border border-skin-muted/30 bg-skin-button-muted/40 hover:bg-skin-button-muted text-skin-base transition-colors flex items-center justify-center'
    aria-label='Toggle background animation'>
    <Icon
      id='animPlayIcon'
      name='ri:play-fill'
      class='hidden'
      width={18}
      height={18}
    />
    <Icon
      id='animPauseIcon'
      name='ri:pause-fill'
      class='hidden'
      width={18}
      height={18}
    />
  </button>

  <!-- Dark/Light theme button -->
  <div
    class='group/theme flex cursor-pointer items-center gap-2 rounded-md bg-transparent'>
    <button
      id='themeSwitch'
      class='cursor-pointer p-2 rounded-full border border-skin-muted/30 bg-skin-button-muted/40 hover:bg-skin-button-muted text-skin-base transition-colors flex items-center justify-center'
      aria-label='Toggle dark mode'>
      <i
        class='flex items-center justify-center transition-transform ease-in-out group-hover/theme:rotate-45'>
        <Icon
          name='ri:moon-fill'
          class='hidden dark:block'
          width={18}
          height={18}
        />
        <Icon name='ri:sun-fill' class='dark:hidden' width={18} height={18} />
      </i>
    </button>
  </div>
</div>

<style>
  :global(.dark) {
    color-scheme: dark;
  }

  /* Toggle the play/pause icon based on data-animation attribute on body */
  :global(body[data-animation="paused"]) #animPlayIcon {
    display: block !important;
  }
  :global(body[data-animation="paused"]) #animPauseIcon {
    display: none !important;
  }
  :global(body:not([data-animation="paused"])) #animPlayIcon {
    display: none !important;
  }
  :global(body:not([data-animation="paused"])) #animPauseIcon {
    display: block !important;
  }
</style>

<script>
  let isDark = false

  function toggleDark(event: MouseEvent) {
    const isAppearanceTransition =
      'startViewTransition' in document &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches

    if (!isAppearanceTransition) {
      isDark = !isDark
      updateTheme()
      return
    }

    const x = event.clientX
    const y = event.clientY
    const endRadius = Math.hypot(
      Math.max(x, innerWidth - x),
      Math.max(y, innerHeight - y)
    )

    // @ts-ignore
    const transition = document.startViewTransition(async () => {
      isDark = !isDark
      updateTheme()
    })

    transition.ready.then(() => {
      const clipPath = [
        `circle(0px at ${x}px ${y}px)`,
        `circle(${endRadius}px at ${x}px ${y}px)`,
      ]
      document.documentElement.animate(
        {
          clipPath: isDark ? [...clipPath].reverse() : clipPath,
        },
        {
          duration: 400,
          easing: 'ease-out',
          pseudoElement: isDark
            ? '::view-transition-old(root)'
            : '::view-transition-new(root)',
        }
      )
    })
  }

  function updateTheme() {
    document.documentElement.classList.toggle('dark', isDark)
    localStorage.setItem('theme', isDark ? 'dark' : 'light')
  }

  const themeSwitchButton = document.getElementById('themeSwitch')
  if (themeSwitchButton) {
    themeSwitchButton.addEventListener('click', toggleDark)
  }

  // Initialize theme: check localStorage, fallback to system preferences (matchMedia)
  if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
    isDark = true
  } else {
    isDark = false
  }
  updateTheme()

  // --- Background Animation Control ---
  let isAnimPaused = false

  function updateAnimationState() {
    document.body.setAttribute('data-animation', isAnimPaused ? 'paused' : 'playing')
    localStorage.setItem('animation', isAnimPaused ? 'paused' : 'playing')
  }

  function toggleAnimation() {
    isAnimPaused = !isAnimPaused
    updateAnimationState()
  }

  const animToggleBtn = document.getElementById('animationToggle')
  if (animToggleBtn) {
    animToggleBtn.addEventListener('click', toggleAnimation)
  }

  // Initialize animation state from localStorage (default to playing)
  if (localStorage.getItem('animation') === 'paused') {
    isAnimPaused = true
  } else {
    isAnimPaused = false
  }
  updateAnimationState()
</script>

<style is:global>
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
    mix-blend-mode: normal;
  }
  ::view-transition-old(root) {
    z-index: 1;
  }
  ::view-transition-new(root) {
    z-index: 9999;
  }
  .dark::view-transition-old(root) {
    z-index: 9999;
  }
  .dark::view-transition-new(root) {
    z-index: 1;
  }
</style>

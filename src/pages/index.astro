---
import Layout from "@/layouts/Layout.astro";

import About from "@/components/sections/About.astro";
import Experience from "@/components/sections/Experience.astro";
import Hero from "@/components/sections/Hero.astro";
import Projects from "@/components/sections/Projects.astro";
import Skills from "@/components/sections/Skills.astro";
import Tail from "@/components/sections/Tail.astro";
import KeyboardManager from "@/components/KeyboardManager.astro";
import ThemeSwitch from "@/components/ThemeSwitch.astro";
import Education from "@/components/sections/Education.astro";
import Classes from "@/components/sections/Classes.astro";
import Images from "@/components/sections/Images.astro";
import AIAssistant from "@/components/AIAssistant.astro";

import CVRaw from "@cv";
import type { CV as CVType } from "@/cv";
const CV = CVRaw as CVType;
const { name, label } = CV.basics;

enum PageLayout {
  SingleColumn = "single-column",
  TwoColumn = "two-column",
  Scroll = "scroll",
}
---

<Layout title={`${name}'s Portfolio - ${label}`}>
  <!-- Floating filter navigation bar -->
  <nav class="fixed top-4 right-4 md:top-6 md:right-6 z-50 print:hidden flex items-center gap-1.5 bg-skin-fill/90 backdrop-blur-md border border-skin-muted/30 px-3 py-1.5 rounded-full shadow-sm font-sc text-[12px] tracking-widest uppercase select-none">
    <button data-filter="all" class="filter-btn px-3 py-1 rounded-full bg-skin-button-accent text-skin-inverted transition-colors duration-200 cursor-pointer font-bold">All</button>
    <button data-filter="projects" class="filter-btn px-3 py-1 rounded-full text-skin-muted hover:text-skin-base hover:bg-skin-button-muted/40 transition-colors duration-200 cursor-pointer font-bold">Projects</button>
    <button data-filter="experience" class="filter-btn px-3 py-1 rounded-full text-skin-muted hover:text-skin-base hover:bg-skin-button-muted/40 transition-colors duration-200 cursor-pointer font-bold">Experience</button>
    <button data-filter="classes" class="filter-btn px-3 py-1 rounded-full text-skin-muted hover:text-skin-base hover:bg-skin-button-muted/40 transition-colors duration-200 cursor-pointer font-bold">Classes</button>
    
    <button id="ai-chat-btn" class="px-3 py-1 rounded-full text-skin-muted hover:text-skin-base hover:bg-skin-button-muted/40 transition-colors duration-200 cursor-pointer font-bold border border-dashed border-skin-muted/30 flex items-center gap-1.5 ml-1">
      <span class="w-1.5 h-1.5 rounded-full bg-stone-400" id="ai-status-dot"></span>
      AI
    </button>
  </nav>

  <main
    class="relative grid h-full max-w-7xl gap-12 p-8 max-sm:py-16 md:min-h-screen md:grid-cols-6 md:p-16 xl:gap-24 print:max-w-none print:grid-cols-1 print:gap-6 mx-auto"
  >
    <div
      class="slide-enter ease-in md:col-span-2 md:sticky md:top-20 self-start print:col-span-1 print:grid print:grid-cols-2 print:gap-5 print:space-y-0"
    >
      <div class="left-column-card md:-m-6 md:p-6 rounded-2xl transition-all duration-300 space-y-8">
        <Hero />
        <About />
        <ThemeSwitch />
      </div>
    </div>
    <div
      class="slide-enter-content space-y-12 md:col-span-4 print:col-span-1 print:grid print:grid-cols-4 print:gap-2 print:space-y-0"
    >
      {
        (CV?.pageLayout === PageLayout.TwoColumn || !CV?.pageLayout) && (
          <Projects className="print:hidden" data-section="projects" />
        )
      }
      <Experience className="print:col-span-3" data-section="experience" />
      {
        (CV?.pageLayout === PageLayout.TwoColumn || !CV?.pageLayout) && (
          <>
            {CV?.images && <Images className="print:hidden" data-section="images" />}
            {CV?.education && <Education className="order-first" data-section="education" />}
            <Classes data-section="classes" />
            <Skills className="print:hidden" data-section="skills" />
          </>
        )
      }
    </div>
  </main>
  {
    CV?.pageLayout !== PageLayout.TwoColumn && (
      <>
        <div class="border-t border-solid border-skin-muted/20 print:hidden" />
        {CV?.pageLayout === PageLayout.SingleColumn && (
          <main class="relative grid max-w-[82rem] gap-12 p-8 max-sm:py-16 md:grid-cols-6 md:p-16 xl:gap-24 print:max-w-none print:grid-cols-1 print:gap-6 mx-auto">
            <div class="slide-enter-content space-y-6 md:col-span-6">
              <Projects className="print:hidden" data-section="projects" />
              {CV?.images && <Images className="print:hidden" data-section="images" />}
              {CV?.education && <Education className="order-first" data-section="education" />}
              <Classes data-section="classes" />
              <Skills className="print:hidden" data-section="skills" />
            </div>
          </main>
        )}

        {CV.pageLayout === PageLayout.Scroll && (
          <main class="max-w-[97%] p-8 max-md:!max-w-7xl max-sm:py-16 print:max-w-none print:grid-cols-1 print:gap-6 mx-auto">
            <div
              id="carousel"
              class="slide-enter-content scrollbar-thin scrollbar-thumb-gray-400 scrollbar-track-gray-200 mx-auto md:col-span-6 md:overflow-x-auto md:overflow-y-auto print:max-w-none print:grid-cols-1 print:gap-6"
            >
              <div class="flex space-x-0 pb-4 max-md:gap-4 max-sm:flex-col max-sm:space-y-4 md:px-4">
                <Projects className="flex-shrink-0 w-full print:hidden border-skin-muted/25 md:border-solid md:border md:p-4" data-section="projects" />
                {CV?.images && (
                  <Images className="flex-shrink-0 w-full print:hidden border-skin-muted/25 md:border-solid md:border md:p-4" data-section="images" />
                )}
                {CV?.education && (
                  <Education className="flex-shrink-0 w-full md:w-1/3 print:order-first border-skin-muted/25 md:border-solid md:border md:p-4" data-section="education" />
                )}
                <Classes className="flex-shrink-0 w-full md:w-1/3 border-skin-muted/25 md:border-solid md:border md:p-4" data-section="classes" />
                <Skills className="flex-shrink-0 w-full md:w-1/3 print:hidden border-skin-muted/25 md:border-solid md:border md:p-4" data-section="skills" />
              </div>
            </div>
          </main>
        )}
      </>
    )
  }
  <Tail />
  <KeyboardManager />
  <AIAssistant />
</Layout>

<script>
  const filterButtons = document.querySelectorAll('.filter-btn');
  const sections = document.querySelectorAll('[data-section]');

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-filter');
      
      // Update active button classes
      filterButtons.forEach(b => {
        b.classList.remove('bg-skin-button-accent', 'text-skin-inverted');
        b.classList.add('text-skin-muted', 'hover:text-skin-base', 'hover:bg-skin-button-muted/40');
      });
      btn.classList.add('bg-skin-button-accent', 'text-skin-inverted');
      btn.classList.remove('text-skin-muted', 'hover:text-skin-base', 'hover:bg-skin-button-muted/40');

      // Toggle display of each section
      sections.forEach(sec => {
        const secName = sec.getAttribute('data-section');
        const element = sec as HTMLElement;
        
        let shouldShow = false;
        if (target === 'all') {
          shouldShow = true;
        } else if (target === 'projects' && secName === 'projects') {
          shouldShow = true;
        } else if (target === 'experience' && (secName === 'experience' || secName === 'education')) {
          shouldShow = true;
        } else if (target === 'classes' && secName === 'classes') {
          shouldShow = true;
        }

        if (shouldShow) {
          element.style.display = '';
          element.classList.remove('opacity-0');
          element.classList.add('animate-fade-in');
        } else {
          element.style.display = 'none';
          element.classList.remove('animate-fade-in');
        }
      });
    });
  });
</script>

<script>
  const carousel = document.querySelector("#carousel");

  if (carousel) {
    let isScrolling = true;
    let scrollSpeed = 2;
    let direction = 1;
    let pauseTimeout: number | undefined;

    const startAutoScroll = () => {
      const scroll = () => {
        if (!isScrolling) return;

        if (
          //@ts-ignore
          carousel.scrollLeft + carousel.offsetWidth >= carousel.scrollWidth ||
          carousel.scrollLeft <= 0
        ) {
          direction *= -1;
          isScrolling = false;
          clearTimeout(pauseTimeout);
          pauseTimeout = setTimeout(() => {
            isScrolling = true;
            requestAnimationFrame(scroll);
          }, 1000) as unknown as number;
        }

        carousel.scrollLeft += scrollSpeed * direction;
        requestAnimationFrame(scroll);
      };

      requestAnimationFrame(scroll);
    };

    const stopAutoScroll = () => {
      isScrolling = false;
    };

    const handleUserInteraction = () => {
      stopAutoScroll();
      setTimeout(() => {
        isScrolling = true;
      }, 500);
    };

    startAutoScroll();

    carousel.addEventListener("mousedown", handleUserInteraction);
    carousel.addEventListener("wheel", handleUserInteraction);
    carousel.addEventListener("touchstart", handleUserInteraction);
  } else {
    console.log('Not in Scroll mode')
  }
</script>

<script>
  const leftCard = document.querySelector('.left-column-card');
  if (leftCard) {
    const handleScroll = () => {
      if (window.scrollY > 30) {
        leftCard.classList.add('scrolled');
      } else {
        leftCard.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
  }
</script>

<style>
  /* 自定义滚动条样式 */
  .scrollbar-thin::-webkit-scrollbar {
    height: 8px;
  }
  .scrollbar-thumb-gray-400::-webkit-scrollbar-thumb {
    background-color: rgba(var(--color-text-muted), 0.3);
    border-radius: 4px;
  }

  .left-column-card {
    transition: background-color 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease, backdrop-filter 0.4s ease;
    border: 1px solid transparent;
  }
  
  @media (min-width: 768px) {
    .left-column-card.scrolled {
      background-color: rgba(var(--color-fill), 0.60);
      border-color: rgba(var(--muted), 0.35);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      box-shadow: 0 14px 42px rgba(var(--color-text-base), 0.04);
    }
  }
</style>

<style is:global>
  * {
    scrollbar-color: rgba(var(--color-text-muted), 0.3) rgba(var(--color-fill), 0.1);
  }

  @page {
    size: auto;
    margin: 0mm;
  }
  main {
    margin: auto;
    width: 100%;
  }

  @keyframes slide-enter {
    0% {
      transform: translateY(10px);
      opacity: 0;
    }

    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .slide-enter,
    .slide-enter-content > *:not(:has(.table-of-contents)) {
      --enter-stage: 0;
      --enter-step: 400ms;
      --enter-initial: 0ms;
      animation: slide-enter 1s both 1;
      animation-delay: calc(
        var(--enter-initial) + var(--enter-stage) * var(--enter-step)
      );
    }

    .slide-enter-content > *:nth-child(1) {
      --enter-stage: 1 !important;
    }
    .slide-enter-content > *:nth-child(2) {
      --enter-stage: 2 !important;
    }
    .slide-enter-content > *:nth-child(3) {
      --enter-stage: 3 !important;
    }
    .slide-enter-content > *:nth-child(4) {
      --enter-stage: 4 !important;
    }
    .slide-enter-content > *:nth-child(5) {
      --enter-stage: 5 !important;
    }
    .slide-enter-content > *:nth-child(6) {
      --enter-stage: 6 !important;
    }
    .slide-enter-content > *:nth-child(7) {
      --enter-stage: 7 !important;
    }
    .slide-enter-content > *:nth-child(8) {
      --enter-stage: 8 !important;
    }
    .slide-enter-content > *:nth-child(9) {
      --enter-stage: 9 !important;
    }
    .slide-enter-content > *:nth-child(10) {
      --enter-stage: 10 !important;
    }
    .slide-enter-content > *:nth-child(11) {
      --enter-stage: 11 !important;
    }
    .slide-enter-content > *:nth-child(12) {
      --enter-stage: 12 !important;
    }
    .slide-enter-content > *:nth-child(13) {
      --enter-stage: 13 !important;
    }
    .slide-enter-content > *:nth-child(14) {
      --enter-stage: 14 !important;
    }
    .slide-enter-content > *:nth-child(15) {
      --enter-stage: 15 !important;
    }
    .slide-enter-content > *:nth-child(16) {
      --enter-stage: 16 !important;
    }
    .slide-enter-content > *:nth-child(17) {
      --enter-stage: 17 !important;
    }
    .slide-enter-content > *:nth-child(18) {
      --enter-stage: 18 !important;
    }
    .slide-enter-content > *:nth-child(19) {
      --enter-stage: 19 !important;
    }
    .slide-enter-content > *:nth-child(20) {
      --enter-stage: 20 !important;
    }
  }
</style>
